<Window x:Class="TurnPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Character Selection" Height="300" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Select Your Character" FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="10" Grid.Row="0"/>
        
        <ScrollViewer Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="CharacterButtonsPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Character buttons added here at startup -->
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="btnAddCharacter" Content="Add Character" Height="30" Width="100" 
                    Click="AddCharacterButton_Click" Margin="5"/>
            <Button Name="btnExit" Content="Exit" Height="30" Width="100" 
                    Click="ExitButton_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
